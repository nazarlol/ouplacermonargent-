---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Bienvenue sur OuPlacerMonArgent.fr</h1>
			<p class="tagline">Apprenez à placer votre argent simplement</p>
			<p>Des guides clairs et pratiques pour comprendre les placements en France : Livret A, PEA, assurance vie, ETF et bien plus.</p>
			<a href="/blog" class="cta">Lire les articles →</a>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: auto;
		padding: 4em 1em;
		text-align: center;
	}
	.tagline {
		font-size: 1.4em;
		color: rgb(var(--gray));
		margin-bottom: 1.5em;
	}
	.cta {
		display: inline-block;
		margin-top: 1.5em;
		padding: 0.75em 1.5em;
		background: var(--accent);
		color: white;
		border-radius: 6px;
		text-decoration: none;
		font-weight: 600;
	}
	.cta:hover {
		background: var(--accent-dark);
		color: white;
	}
</style>
